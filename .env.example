# --- Telegram Bot Configuration ---

# 1. Your Bot Token from @BotFather
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrSTUvwxYZ"

# 2. Your API ID and Hash from https://my.telegram.org/apps
# (Required for Pyrogram to unlock the 2GB upload limit)
TELEGRAM_API_ID="1234567"
TELEGRAM_API_HASH="0123456789abcdef0123456789abcdef"

# 3. Allowed Admin Telegram IDs
# Only users with these IDs can interact with the bot. Comma-separated.
# You can get your ID from bots like @userinfobot
ALLOWED_ADMIN_IDS="123456789,987654321,-23232,-3434"
